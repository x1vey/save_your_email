# Copy to .env.local and fill in ONE provider (or both).
# Without any key the app still runs — it falls back to a deterministic
# rule-based report instead of the AI-written one.

# Which provider to use for the report writer: "groq" or "openai".
# If omitted, it auto-selects whichever key below is present (Groq preferred).
LLM_PROVIDER=groq

# --- Groq (OpenAI-compatible, fast & cheap) ---
GROQ_API_KEY=
# Optional model override. Default: llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenAI ---
OPENAI_API_KEY=
# Optional model override. Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# --- Supabase (Postgres + RLS + Auth) ---
# Without these the app runs anonymously and skips persistence.
# Apply supabase/migrations/0001_init.sql, and enable "Anonymous sign-ins" in
# Supabase → Authentication → Providers for per-account limits/RLS to engage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Upstash Redis (rate limiting) ---
# Without these, rate limiting fails OPEN (disabled). Required in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- CORS ---
# Same-origin is always allowed. Add extra allowed origins (comma-separated) here.
# ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
